# ============================================================
# BTS / IILM Admin Dashboard — environment configuration
# Copy this file to `.env.local` and fill in real values.
#
# Nothing here is hardcoded in the app: the dashboard reads all of
# the values below from the environment. Only the admin PASSWORD has a
# hardcoded fallback (see lib/config.ts) so the app still boots without
# any env file during local development.
# ============================================================

# Base URL of the FastAPI backend (no trailing slash).
BTS_API_BASE=https://apps.iilm.edu/bts-api

# Shared secret sent as the X-API-Key header to the backend.
# Must match the backend's BTS_API_KEY env var. Stays SERVER-SIDE only
# (never shipped to the browser — all calls are proxied).
BTS_API_KEY=bts_admin_2024_change_me

# Division login passwords. If unset, fall back to values in lib/config.ts.
ADMIN_PASSWORD=bts_admin_2024
HR_PASSWORD=bts_hr_2024

# Secret used to sign the session cookie. Set to any long random string.
SESSION_SECRET=change-me-to-a-long-random-string
