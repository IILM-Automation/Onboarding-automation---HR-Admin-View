# Copy to `.env` and fill in real values. Loaded automatically by main.py.

# PostgreSQL connection. Encode special chars in the password
# (e.g. an `@` becomes `%40`).
BTS_DB_URL=postgresql://<user>:<password>@localhost:<port>/bts_f2f_info

# Shared secret for admin endpoints — must match the dashboard's BTS_API_KEY.
BTS_API_KEY=bts_admin_2024_change_me

# HR invite flow
# n8n webhook that emails the candidate the tokenised form link.
N8N_INVITE_WEBHOOK_URL=https://apps.iilm.edu/webhook/bts-send-invite
# Public base URL of the candidate form (token appended as ?token=...).
FORM_BASE_URL=https://your-candidate-portal.example.com
INVITE_VALID_DAYS=7
WEBHOOK_TIMEOUT_SECS=7
